# ── MQTT ────────────────────────────────────────────────────────────────────
# Broker is Mosquitto running in Docker — containers reference it by name
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=smartcity
MQTT_PASSWORD=password

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=smartcity-super-secret-token
INFLUXDB_ORG=smartcity
INFLUXDB_BUCKET=waste_monitoring

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
