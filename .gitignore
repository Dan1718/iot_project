# Environment — copy to .env and fill in
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Data volumes (generated at runtime)
mosquitto/data/
mosquitto/log/

# Certbot runtime (certs are generated on the server, not committed)
nginx/certbot/conf/
nginx/certbot/www/

# Mosquitto password files (generated by setup)
mosquitto/config/passwd
mosquitto/config/passwd_app

# Node
node_modules/
worker-console/dist/
worker-console/.vite/
worker-mobile/.expo/
worker-mobile/dist/

# macOS
.DS_Store
.DS_Store?

# Docker build artifacts
*.pid
